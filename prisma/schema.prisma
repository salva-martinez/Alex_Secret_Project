// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- AUTENTICACIÓN (Username + Password) ---

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  files        Media[]
  createdAt    DateTime @default(now())
}

// --- WHITELIST (Invitaciones por username) ---

model AllowedUser {
  id        String   @id @default(cuid())
  username  String   @unique
  invitedBy String?
  createdAt DateTime @default(now())
}

// --- GESTIÓN MULTIMEDIA ---

model Media {
  id          String   @id @default(cuid())
  title       String?
  url         String
  fileKey     String
  type        FileType @default(IMAGE)
  mimeType    String
  size        Int
  width       Int?
  height      Int?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

// --- ENUMS ---

enum Role {
  USER
  ADMIN
}

enum FileType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  ARCHIVE
}
