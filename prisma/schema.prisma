// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- AUTENTICACIÓN (NextAuth + Magic Links) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  files         Media[]   // Relación con los archivos que sube
  createdAt     DateTime  @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- LÓGICA DE INVITACIÓN (Whitelist) ---

model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  invitedBy String?  // Email del admin que lo invitó
  createdAt DateTime @default(now())
}

// --- GESTIÓN MULTIMEDIA ---

model Media {
  id          String   @id @default(cuid())
  title       String?
  url         String   // URL pública de S3 o Cloudinary
  fileKey     String   // Identificador interno en el storage para poder borrarlo
  type        FileType @default(IMAGE)
  mimeType    String   // Ejemplo: image/jpeg, video/mp4
  size        Int      // Tamaño en bytes
  width       Int?     // Para imágenes/videos
  height      Int?     // Para imágenes/videos
  
  // Relaciones
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

// --- ENUMS ---

enum Role {
  USER
  ADMIN
}

enum FileType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  ARCHIVE
}